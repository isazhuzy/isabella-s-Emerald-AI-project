# ---- Claude (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-...
# Set this to a current model id you have access to (e.g. an Opus or Sonnet variant).
EMERALD_MODEL=claude-sonnet-4-5

# ---- Loxo Open API (paid feature) ----
# Get these from Loxo: Settings > API Keys (admin only) for the token;
# contact Loxo Support for your agency domain + slug.
LOXO_DOMAIN=youragency.app.loxo.co
LOXO_SLUG=your-agency-slug
LOXO_API_KEY=your-bearer-token

# Loxo REQUIRES these on job creation. Fetch valid IDs first:
#   GET /api/{slug}/job_types
#   GET /api/{slug}/companies   (or create the company assignment)
LOXO_DEFAULT_JOB_TYPE_ID=
LOXO_DEFAULT_COMPANY_ID=

# ---- B1 (Loxo-native sourcing) — see LOXO_SETUP.md ----
# Optional: owner for created records / activities.
LOXO_DEFAULT_OWNER_ID=
# Activity type id used to post the Sourcing Brief as a job note.
# Discover via: python -c "from emerald.loxo import LoxoClient; print(LoxoClient().activity_types())"
# Leave blank to skip posting the note on --push.
LOXO_NOTE_ACTIVITY_TYPE_ID=
# These names MUST match the stages/campaign in your Loxo workflow (LOXO_SETUP.md).
# Defaults below match the live Emerald Resource Group workflow:
#   Long List  = the full 75-150 long list (no enrichment, free)
#   Short List = the top 15-20 shortlist (enrichment + outreach fire here)
LOXO_SOURCING_STAGE_NAME=Long List
LOXO_OUTREACH_STAGE_NAME=Short List
LOXO_OUTREACH_CAMPAIGN_NAME=Confidential Outreach
# Enrichment cost-control: only this many move to the Outreach stage.
EMERALD_ENRICH_TOP_N=20
